CROWN_DASHBOARD_PORT=8787
CROWN_DB_PATH=/app/storage/crown.sqlite
CROWN_STATIC_DIR=/app/frontend/dist
CROWN_DASHBOARD_PASSWORD_SCRYPT=
CROWN_DASHBOARD_SESSION_KEY=
CROWN_DASHBOARD_ALLOWED_HOSTS=
CROWN_DASHBOARD_ALLOWED_ORIGINS=
CROWN_BETTING_ALLOWED_ORIGINS=

# Keep credentials, session signing material, local encryption keys, databases,
# and Telegram tokens in the ignored runtime .env/config/storage paths only.
# Never pass them as Docker build arguments or commit real values here.
# Betting origin entries and account URLs must be exact public HTTPS origins
# without credentials, path/query/hash, localhost, private hosts, or IP literals.

# Local Node.js defaults:
# CROWN_DB_PATH=storage/crown.sqlite
# CROWN_LOCAL_SECRET_KEY_PATH=storage/crown-local-secret.key
